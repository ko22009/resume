{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all -p -r development style:generate:watch",
    "development": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next export",
    "lint": "next lint",
    "style:generate": "typed-scss-modules **/*.module.scss --aliasPrefixes.~",
    "style:generate:watch": "yarn style:generate -w --logLevel error"
  },
  "dependencies": {
    "classnames": "^2.3.1",
    "next": "12.1.5",
    "react": "18.0.0",
    "react-dom": "18.0.0"
  },
  "devDependencies": {
    "@types/node": "17.0.24",
    "@types/react": "18.0.5",
    "@types/react-dom": "18.0.1",
    "eslint": "8.13.0",
    "eslint-config-next": "12.1.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2",
    "sass": "^1.50.0",
    "typed-scss-modules": "^6.2.0",
    "typescript": "4.6.3"
  }
}
